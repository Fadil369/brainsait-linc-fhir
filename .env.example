# Environment Template - BotFather v2.1
# Copy to .env and fill in your values
# NEVER commit .env to git!

# Cloudflare Configuration
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Target Zones (comma-separated)
TARGET_ZONES=brainsait.org,elfadil.com,brainsait.com,brainsait.io

# GitHub Configuration  
GITHUB_REPO=fadil369/brainsait-linc-fhir
GITHUB_TOKEN=

# API Endpoints
FHIR_API_URL=https://fhir.brainsait.org/r4
PATIENT_API_URL=https://api.brainsait.org/patients
AGENT_API_URL=https://api.brainsait.org/agents
